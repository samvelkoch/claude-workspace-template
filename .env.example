# Скопировать в .env и заполнить. .env в git не коммитится.
# .env автоматически копируется в worktree через .worktreeinclude.

# --- Подключения к данным (БД, хранилища) ---
# DB_HOST=
# DB_PORT=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# --- Внешние сервисы / API ---
# SERVICE_BASE_URL=
# SERVICE_TOKEN=

# --- LLM (если используется) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OPENAI_BASE_URL=

# --- Параметры запуска ---
# RANDOM_SEED=42
# DATA_DIR=./data
# LOGS_DIR=./logs
