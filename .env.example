# Скопировать в .env и заполнить. .env в git не коммитится.
# .env автоматически копируется в worktree через .worktreeinclude.

# --- Подключения к данным ---

# ClickHouse (clickhouse.aeroclub.int)
# CH_HOST=
# CH_PORT=
# CH_USER=
# CH_PASSWORD=

# DWH SQL Server mow2bi2
# MOW2BI2_HOST=
# MOW2BI2_DATABASE=
# MOW2BI2_USER=
# MOW2BI2_PASSWORD=

# --- Confluence / Wiki ---
# Токен лежит в ~/.confluence_token (chmod 600). Здесь только URL если нужен.
# CONFLUENCE_BASE_URL=https://wiki.aeroclub.int

# --- LLM (если используется) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OPENAI_BASE_URL=

# --- Параметры эксперимента ---
# RANDOM_SEED=42
# DATA_DIR=./data
# LOGS_DIR=./logs
